{
    "name": "waffle-commons/skeleton",
    "description": "The official skeleton for Waffle Framework applications.",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Scripts\\": "scripts/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppTests\\": "tests/src/"
        }
    },
    "authors": [
        {
            "name": "Leslie Petrimaux",
            "email": "contact@waffle-commons.cloud"
        }
    ],
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "ext-yaml": "*",
        "ext-zend-opcache": "*",
        "waffle-commons/cache": "self.version",
        "waffle-commons/config": "self.version",
        "waffle-commons/container": "self.version",
        "waffle-commons/contracts": "self.version",
        "waffle-commons/console": "self.version",
        "waffle-commons/data": "self.version",
        "waffle-commons/error-handler": "self.version",
        "waffle-commons/event-dispatcher": "self.version",
        "waffle-commons/http": "self.version",
        "waffle-commons/http-client": "self.version",
        "waffle-commons/log": "self.version",
        "waffle-commons/pipeline": "self.version",
        "waffle-commons/routing": "self.version",
        "waffle-commons/runtime": "self.version",
        "waffle-commons/security": "self.version",
        "waffle-commons/utils": "self.version",
        "waffle-commons/waffle": "self.version"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "carthage-software/mago": "^1.29",
        "vimeo/psalm": "^6.16",
        "php-mock/php-mock-phpunit": "^2.15",
        "cyclonedx/cyclonedx-php-composer": "^6.2",
        "igor-php/igor-php": "^0.6.3"
    },
    "scripts": {
        "igor": "vendor/bin/igor-php .",
        "post-create-project-cmd": [
            "Scripts\\Setup::postCreateProject"
        ],
        "post-install-cmd": [
            "Scripts\\Setup::postInstall"
        ],
        "post-update-cmd": [
            "Scripts\\Setup::postInstall"
        ],
        "auto-scripts": {
            "cache:clear": "rm -rf var/cache/*"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "carthage-software/mago": true,
            "cyclonedx/cyclonedx-php-composer": true
        },
        "sort-packages": true
    }
}
