<?php

declare(strict_types=1);

/**
 * Reference entry point for the `waffle` CLI.
 *
 * Skeleton-shipped projects ship their own bin/waffle.php that wires the
 * concrete cache + router + container; this file is a minimal reference
 * showing the expected boot shape.
 *
 * Usage:
 *   php vendor/bin/waffle <command> [options...]
 *   php vendor/bin/waffle list
 */

use App\Factory\AppKernelFactory;
use Waffle\Commons\Config\Config;
use Waffle\Commons\Console\Command\CacheClearCommand;
use Waffle\Commons\Console\Command\DataWarmupCommand;
use Waffle\Commons\Console\Command\MigrateCommand;
use Waffle\Commons\Console\Command\RouteListCommand;
use Waffle\Commons\Console\Command\SecurityAuditCommand;
use Waffle\Commons\Console\ConsoleApplication;
use Waffle\Commons\Console\Output\StreamOutput;
use Waffle\Commons\Container\Container;
use Waffle\Commons\Contracts\Constant\Constant;
use Waffle\Commons\Contracts\Data\Enum\Direction;
use Waffle\Commons\Data\Compiler\SQLCompiler;
use Waffle\Commons\Data\Compiler\SQLDialect;
use Waffle\Commons\Data\Migration\MigrationRunner;
use Waffle\Commons\Data\Query\Query;
use Waffle\Commons\Data\Warmup\QueryWarmer;
use Waffle\Commons\Routing\Router;
use Waffle\Commons\Contracts\Data\Connection\ConnectionPoolInterface;
use Waffle\Commons\Contracts\Data\Migration\MigrationRunnerInterface;
use Waffle\Commons\Security\Container\SecureContainer;
use Waffle\Commons\Security\Security;

require_once __DIR__ . '/../vendor/autoload.php';

/** @var string $root */
$root = realpath(path: dirname(path: __DIR__));
$rootConfig = $root . DIRECTORY_SEPARATOR . 'config';

// Setting up the framework
$container = new Container();
$config = new Config(configDir: $rootConfig, environment: Constant::ENV_DEV);
$security = new Security($config);
$secureContainer = new SecureContainer($container, $security);
$cache = AppKernelFactory::buildCache($root, $config);
$router = new Router(directory: $config->getString(key: 'waffle.paths.controllers'));

// PDO connection pool (RFC-022) + migration runner, built here on the explicit
// CLI path so no migration scan ever happens during an HTTP request.
$connectionPool = AppKernelFactory::buildConnectionPool($config);
$migrationRunner = new MigrationRunner(pool: $connectionPool, config: $config);

$container->set(ConnectionPoolInterface::class, $connectionPool);
$container->set(MigrationRunnerInterface::class, $migrationRunner);

// Console application
$app = new ConsoleApplication(
    name: 'Waffle',
    version: '0.1.0-beta0',
    output: new StreamOutput(),
);


// Adding commands
$app->add(command: new RouteListCommand(router: $router->boot(container: $secureContainer)));
$app->add(command: new SecurityAuditCommand(router: $router->boot(container: $secureContainer)));
$app->add(command: new CacheClearCommand(cache: $cache));
$app->add(command: new MigrateCommand(
    runner: $container->get(MigrationRunnerInterface::class),
    pool: $container->get(ConnectionPoolInterface::class),
));

// Pre-compiled SQR warmup (`data:warmup`) — Roadmap Beta-3 "CLI Route & Cache
// Warmup". The hot read queries below are compiled once to parameterised SQL,
// serialised under var/cache/ and primed into OPcache shared memory, so the
// first live request never pays the AST walk. Adapt the registry to your own
// hot paths; warming never executes SQL against the database.
$app->add(command: new DataWarmupCommand(warmers: [
    new QueryWarmer(
        queries: [
            'users.recent' => Query::select('id')
                ->from('users')
                ->orderBy('id', Direction::Descending)
                ->limit(20),
        ],
        compiler: new SQLCompiler(dialect: SQLDialect::MySQL),
        cacheFile: $root . '/var/cache/data-warmup.php',
    ),
]));

exit($app->run());
