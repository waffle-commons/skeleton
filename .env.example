# -----------------------------------------------------------------------------
# Waffle Application Configuration
# -----------------------------------------------------------------------------

# Application Environment (prod, dev, test)
APP_ENV=dev

# Debug Mode (true/false)
# In production, this should be set to false (0)
APP_DEBUG=true

# Application Secret
# This is used for encryption and signing.
# It is automatically generated during 'composer create-project'.
APP_SECRET=ChangeMeInProduction

# -----------------------------------------------------------------------------
# Docker / Infrastructure
# -----------------------------------------------------------------------------

# Server Name (Caddy)
# Used for automatic HTTPS generation in production
SERVER_NAME=localhost

# Exposed Ports (Docker Compose)
HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443
