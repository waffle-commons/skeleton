# -----------------------------------------------------------------------------
# Waffle Application Configuration
# -----------------------------------------------------------------------------
#
# PRECEDENCE: any variable also exported by the OS / Docker / Kubernetes wins
# over the value in this file. AppKernelFactory does:
#     array_merge((new DotEnv($root))->load(), getenv())
# array_merge is rightmost-wins on string keys, so the process environment
# silently overrides .env on collision. This file is intended for local-dev
# defaults; production values should come from your orchestrator.
#
# BOOLEAN NORMALIZATION: APP_DEBUG and DEBUG are normalized by DotEnv
# (true/yes/on/1 -> '1', false/no/off/0 -> '0'). The OS does NOT perform this
# normalization -- if you export APP_DEBUG=yes from your shell, Config::getBool()
# will throw because 'yes' is not a YAML boolean. Use true/false (or 1/0).
#
# See documentation/how-to/configuration.md for the full discussion.
# -----------------------------------------------------------------------------

# Application Environment (prod, dev, test)
APP_ENV=dev

# Debug Mode (true/false)
# In production, this should be set to false (0)
APP_DEBUG=true

# Application Secret
# This is used for encryption and signing.
# It is automatically generated during 'composer create-project'.
APP_SECRET=ChangeMeInProduction

# -----------------------------------------------------------------------------
# Docker / Infrastructure
# -----------------------------------------------------------------------------

# Server Name (Caddy)
# Used for automatic HTTPS generation in production
SERVER_NAME=localhost

# Exposed Ports (Docker Compose)
HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443

# Redis Cache
REDIS_DSN=null

# -----------------------------------------------------------------------------
# CSRF Protection
# 32+ byte signing secret for stateless HMAC-signed CSRF tokens (Beta-1 / SEC-01).
# -----------------------------------------------------------------------------

WAFFLE_CSRF_SECRET=ChangeMeInProduction

# -----------------------------------------------------------------------------
# Database (RFC-022) — local development credentials
# Consumed by waffle.database.* in config/app.yaml and the bin/waffle db:migrate
# command. Override these from your orchestrator in production.
# -----------------------------------------------------------------------------

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=waffle
DB_USER=waffle
DB_PASSWORD=ChangeMeInProduction
